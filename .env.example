# DeepSeek API key for the composting agent
# Get it from: platform.deepseek.com > API Keys
DEEPSEEK_API_KEY=sk-...

# Neon Postgres connection string
# Get it from: Vercel > Storage > your Neon DB > .env.local
# Or from: Neon Console > Connection Details
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
