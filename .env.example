# ============================================================
# Composta Lirio — variables de entorno
# ============================================================

# --- Base de datos (Neon Postgres) ---
# Conexión serverless. Obtenla en: Vercel > Storage > Neon DB > .env.local
# o en: Neon Console > Connection Details.
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# --- LLM de chat / diagnóstico (DeepSeek) ---
# Usado por /api/chat y /api/diagnostico. Key en platform.deepseek.com > API Keys.
DEEPSEEK_API_KEY=sk-...

# --- LLM de visión (OpenAI) ---
# Usado por /api/analizar para el análisis de foto de composta.
OPENAI_API_KEY=sk-...

# --- Vercel Blob (almacenamiento de fotos) ---
# Usado por /api/upload y la eliminación de blobs en /api/mediciones.
# Lo provee Vercel automáticamente si tienes un Blob store enlazado;
# si corres local sin vercel link, pégalo aquí manualmente.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# --- Acceso por PIN ---
# Middleware (middleware.ts) bloquea la app si este valor está definido y
# no coincide con la cookie access_pin. Si no lo defines, el acceso es libre
# (útil para desarrollo local). Compara como texto plano.
ACCESS_PIN=1234
